auto bond0
auto bond0.<%= @vlan %>

iface bond0 inet manual
  slaves <%= @ifaces_linked %>
  bond-mode 802.3ad
  bond-miimon 100

<%- if @logical_primary_interface == 'bond0' -%>
iface bond0.<%= @vlan %> inet static
  vlan-raw-device bond0
  address <%= @ipaddress %>
  netmask <%= @netmask %>
  gateway <%= @gateway %>

iface bond0.<%= @vlan %> inet6 static
  vlan-raw-device bond0
  address <%= @ipaddress6 %>
  netmask <%= @netmask6 %>
  gateway <%= @gateway6 %>
<% else %>
iface bond0.<%= @vlan %> inet manual
  vlan-raw-device bond0

iface bond0.<%= @vlan %> inet6 manual
  vlan-raw-device bond0
<% end %>
